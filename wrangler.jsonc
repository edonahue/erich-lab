{
  "$schema": "./node_modules/wrangler/config-schema.json",
  "name": "erich-lab",
  "compatibility_date": "2026-06-27",
  "routes": [
    {
      "pattern": "lab.erichdonahue.com",
      "custom_domain": true
    }
  ],
  "assets": {
    "directory": "./public",
    "not_found_handling": "404-page",
    "html_handling": "auto-trailing-slash"
  }
}
