---
import { getCollection, render } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import DownloadMenu from '../../components/DownloadMenu.astro';

export async function getStaticPaths() {
  const experiments = await getCollection('experiments', ({ data }) => data.published);
  return experiments.map((experiment) => ({
    params: { slug: experiment.data.slug },
    props: { experiment },
  }));
}

const { experiment } = Astro.props;
const { Content } = await render(experiment);
const launchPath = `/experiments/${experiment.data.slug}/`;
const graduated = experiment.data.status === 'Graduated' && experiment.data.destinationUrl;
const primaryHref = graduated ? experiment.data.destinationUrl : launchPath;
const primaryLabel = graduated ? 'Visit graduated project' : 'Launch experiment';
const created = experiment.data.created.toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'short',
  day: 'numeric',
});
const updated = experiment.data.updated.toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'short',
  day: 'numeric',
});

const pageUrl = new URL(`/projects/${experiment.data.slug}/`, Astro.site).toString();
const blogPostingSchema = {
  '@context': 'https://schema.org',
  '@type': 'BlogPosting',
  headline: experiment.data.title,
  description: experiment.data.summary,
  url: pageUrl,
  datePublished: experiment.data.created.toISOString().slice(0, 10),
  dateModified: experiment.data.updated.toISOString().slice(0, 10),
  author: {
    '@type': 'Person',
    '@id': 'https://erichdonahue.com/#erich',
    name: 'Erich Donahue',
    url: 'https://erichdonahue.com/',
  },
  isPartOf: { '@id': 'https://lab.erichdonahue.com/#website' },
  keywords: experiment.data.technologies.join(', '),
};
---

<BaseLayout
  title={`${experiment.data.title} · Erich's Lab`}
  description={experiment.data.summary}
  image={experiment.data.image}
>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(blogPostingSchema)} />
  </Fragment>
  <section class="project-hero shell">
    <div>
      <p class="eyebrow">{experiment.data.kind} · {experiment.data.status}</p>
      <h1>{experiment.data.title}</h1>
      <p class="lede">{experiment.data.summary}</p>
      <p class="project-dates">Created {created} · Updated {updated}</p>
      <div class="tags">{experiment.data.technologies.map((technology) => <span>{technology}</span>)}</div>
      <div class="hero-actions">
        <a class="button primary" href={primaryHref}>{primaryLabel}</a>
        <DownloadMenu offline={experiment.data.offline} />
        <a class="button" href={experiment.data.sourceUrl}>View source</a>
      </div>
      {
        experiment.data.offline && (
          <p class:list={['download-note', `download-note--${experiment.data.offline.status}`]}>
            <strong>
              {experiment.data.offline.status === 'full' ? 'Full offline edition.' : 'Limited offline edition.'}
            </strong>{' '}
            {experiment.data.offline.note}
          </p>
        )
      }
    </div>
    {experiment.data.image && <img src={experiment.data.image} alt="" />}
  </section>
  <article class="prose shell"><Content /></article>
</BaseLayout>
