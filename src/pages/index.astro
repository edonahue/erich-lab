---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import site from '../data/site.json';

const experiments = (await getCollection('experiments', ({ data }) => data.published)).sort((a, b) => {
  if (a.data.featured !== b.data.featured) return a.data.featured ? -1 : 1;
  return b.data.updated.getTime() - a.data.updated.getTime();
});
---
<BaseLayout>
  <section class="hero shell">
    <p class="eyebrow">{site.eyebrow}</p>
    <h1>{site.headline}</h1>
    <p class="lede">{site.introduction}</p>
    <div class="hero-actions">
      <a class="button primary" href="#experiments">Browse experiments</a>
      <a class="button" href={site.repositoryUrl}>View the repository</a>
    </div>
  </section>

  <section class="catalog shell" id="experiments" aria-labelledby="experiments-title">
    <div class="section-heading">
      <div>
        <p class="eyebrow">{site.experimentsEyebrow}</p>
        <h2 id="experiments-title">{site.experimentsHeading}</h2>
      </div>
      <p>{experiments.length} on the shelf</p>
    </div>

    <div class="experiment-grid">
      {experiments.map((experiment) => {
        const launchPath = `/experiments/${experiment.data.slug}/`;
        return (
          <article class:list={['experiment-card', { featured: experiment.data.featured }] }>
            {experiment.data.image && <img class="preview" src={experiment.data.image} alt="" />}
            <div class="card-meta"><span>{experiment.data.kind}</span><span>{experiment.data.status}</span></div>
            <h3>{experiment.data.title}</h3>
            <p>{experiment.data.summary}</p>
            <div class="tags">
              {experiment.data.technologies.map((technology) => <span>{technology}</span>)}
            </div>
            <div class="card-actions">
              <a class="button primary" href={launchPath}>Launch</a>
              <a class="text-link" href={`/projects/${experiment.data.slug}/`}>Read notes</a>
              <a class="text-link" href={experiment.data.sourceUrl}>Source</a>
            </div>
          </article>
        );
      })}
    </div>
  </section>

  <section class="principles shell" id="about" aria-labelledby="about-title">
    <div>
      <p class="eyebrow">{site.principlesEyebrow}</p>
      <h2 id="about-title">{site.principlesHeading}</h2>
    </div>
    <div class="principle-grid">
      {site.principles.map((principle, index) => (
        <article>
          <span class="principle-number">{String(index + 1).padStart(2, '0')}</span>
          <h3>{principle.title}</h3>
          <p>{principle.description}</p>
        </article>
      ))}
    </div>
  </section>
</BaseLayout>
