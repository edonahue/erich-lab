---
interface OfflineFormat {
  type: 'html' | 'zip' | 'pdf';
  label: string;
  href: string;
  filename?: string;
  note?: string;
}

interface Props {
  offline?: {
    status: 'full' | 'limited';
    note?: string;
    formats: OfflineFormat[];
  };
}

const { offline } = Astro.props;
---

{
  offline && (
    <div class="download-actions">
      {offline.formats.map((format) => (
        <a
          class:list={['button', 'download-button', `download-button--${offline.status}`]}
          href={format.href}
          download={format.filename || true}
          title={format.note || offline.note || undefined}
        >
          {format.label}
        </a>
      ))}
    </div>
  )
}
