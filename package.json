{
  "name": "erich-lab",
  "version": "0.2.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "npm run build:offline && astro dev",
    "build:offline": "node scripts/build-offline.mjs",
    "build": "npm run build:offline && astro build",
    "preview": "astro preview",
    "validate": "npm run build:offline && node scripts/validate-lab.mjs",
    "check": "npm run validate && astro build",
    "deploy": "npm run build && wrangler deploy"
  },
  "dependencies": {
    "astro": "^6.0.0"
  },
  "devDependencies": {
    "wrangler": "^4.0.0"
  },
  "engines": {
    "node": ">=22"
  }
}
